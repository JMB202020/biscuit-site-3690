---
import '../styles/site.css';
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Contact | Hazelcourt Boarding Kennels &amp; Cattery</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/3690/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/3690/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-brand-bg">

    <!-- Preview banner -->
    <div class="bg-brand-accent text-white py-2 px-4 text-center text-sm">
      <div class="max-w-4xl mx-auto flex items-center justify-center gap-3 flex-wrap">
        <span>Preview for <strong>Hazelcourt Boarding Kennels &amp; Cattery</strong> by <strong>Biscuit Web</strong></span>
        <a href="https://biscuitweb.co.uk/activate?id=3690&name=Hazelcourt%20Boarding%20Kennels%20%26%20Cattery" class="inline-flex items-center px-4 py-1 bg-white text-brand-accent font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Just &pound;20/month
        </a>
      </div>
    </div>

    <!-- Nav -->
    <header class="bg-white border-b border-border sticky top-0 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/3690" class="font-display font-extrabold text-xl text-ink">🐾 Hazelcourt Boarding Kennels &amp; Cattery</a>
        <button class="md:hidden p-2 text-ink-soft" onclick="document.getElementById('mobile-nav-3690').classList.toggle('hidden')" aria-label="Menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-8">
          <a href="/3690" class="text-sm text-ink-soft hover:text-brand-accent font-semibold transition-colors">Home</a>
          <a href="/3690/services" class="text-sm text-ink-soft hover:text-brand-accent font-semibold transition-colors">Services</a>
          <a href="/3690/gallery" class="text-sm text-ink-soft hover:text-brand-accent font-semibold transition-colors">Gallery</a>
          <a href="/3690/contact" class="text-sm text-brand-accent font-semibold transition-colors">Contact</a>
          <a href="/3690/contact" class="inline-flex items-center px-5 py-2 bg-brand-accent text-white font-display font-bold text-sm rounded hover:opacity-90 transition-opacity">Get in touch</a>
        </nav>
      </div>
      <nav id="mobile-nav-3690" class="hidden md:hidden px-6 pb-4 space-y-3">
        <a href="/3690" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Home</a>
        <a href="/3690/services" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Services</a>
        <a href="/3690/gallery" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Gallery</a>
        <a href="/3690/contact" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Contact</a>
        <a href="/3690/contact" class="block px-5 py-2.5 bg-brand-accent text-white font-display font-bold text-sm rounded text-center hover:opacity-90 transition-opacity">Get in touch</a>
      </nav>
    </header>


    <section class="relative py-20 sm:py-28 overflow-hidden">
      <img src="/3690/images/465026800-17881390536164947-657360190759-2.jpg" alt="" class="absolute inset-0 w-full h-full object-cover z-[1]" loading="lazy" />
      <div class="absolute inset-0 z-[2] bg-black/70"></div>
      <div class="relative z-[3] mx-auto max-w-4xl px-6">
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-white">Contact Us</h1>
        <p class="mt-4 text-white/70 text-lg">Get in touch with Hazelcourt Boarding Kennels &amp; Cattery.</p>
      </div>
    </section>

    <section class="bg-cream-dark py-20">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="font-display font-extrabold text-3xl text-ink mb-10 text-center">Get in Touch</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="space-y-6">
            <p class="text-ink text-lg"><strong>Phone:</strong> <a href="tel:+447347266528" class="text-brand-accent hover:underline">+44 7347 266528</a></p>
            
            <p class="text-ink-soft"><strong>Address:</strong> Button Street  Swanley BR8 8DX</p>
          </div>
          <form class="bg-cream-dark border border-border rounded-lg p-8 space-y-4" onsubmit="event.preventDefault(); this.querySelector('.form-success').style.display='block'; this.querySelector('button').disabled=true;">
            <div>
              <label class="text-ink-soft text-sm font-semibold block mb-1">Name</label>
              <input type="text" required class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-ink text-sm outline-none focus:border-brand-accent" placeholder="Your name" />
            </div>
            <div>
              <label class="text-ink-soft text-sm font-semibold block mb-1">Email</label>
              <input type="email" required class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-ink text-sm outline-none focus:border-brand-accent" placeholder="Your email" />
            </div>
            <div>
              <label class="text-ink-soft text-sm font-semibold block mb-1">Phone</label>
              <input type="tel" class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-ink text-sm outline-none focus:border-brand-accent" placeholder="Your phone number (optional)" />
            </div>
            <div>
              <label class="text-ink-soft text-sm font-semibold block mb-1">Message</label>
              <textarea rows="4" required class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-ink text-sm outline-none focus:border-brand-accent resize-vertical" placeholder="How can we help?"></textarea>
            </div>
            <button type="submit" class="w-full px-6 py-3 bg-brand-accent text-white font-display font-bold text-sm rounded-lg hover:opacity-90 transition-opacity">Send Message</button>
            <p class="form-success text-center text-sm font-semibold" style="display:none;color:#059669">Thanks! We will be in touch soon.</p>
          </form>
        </div>
      </div>
    </section>

    <section class="bg-white py-12">
      <div class="mx-auto max-w-4xl px-6">
        <div class="rounded-xl overflow-hidden">
          <iframe src="https://www.google.com/maps?q=Button%20Street%20%20Swanley%20BR8%208DX&output=embed" width="100%" height="300" style="border:0" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Map showing Hazelcourt Boarding Kennels &amp; Cattery"></iframe>
        </div>
      </div>
    </section>


    <footer class="bg-cream-dark border-t border-border py-12">
      <div class="mx-auto max-w-7xl px-6">
        <div class="flex flex-col md:flex-row justify-between gap-8">
          <div>
            <p class="font-display font-extrabold text-lg text-ink">Hazelcourt Boarding Kennels &amp; Cattery</p>
            <p class="mt-2 text-ink-soft text-sm">Button Street  Swanley BR8 8DX</p>
            <p class="mt-2"><a href="tel:+447347266528" class="text-brand-accent hover:underline text-sm">+44 7347 266528</a></p>
            
          </div>
          
          <nav class="flex flex-wrap gap-6">
            <a href="/3690" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Home</a>
            <a href="/3690/services" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Services</a>
            <a href="/3690/gallery" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Gallery</a>
            <a href="/3690/contact" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Contact</a>
          </nav>
        </div>
        <div class="mt-8 pt-6 border-t border-border">
          <p class="text-ink-whisper text-xs">&copy; 2026 Hazelcourt Boarding Kennels &amp; Cattery. All rights reserved.</p>
        </div>
      </div>
    </footer>

  </body>
</html>
